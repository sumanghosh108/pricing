    <div class="flex flex-col items-center justify-center space-y-4" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem;">
      <!-- Copyright Text -->
      <p class="text-slate-400 text-sm text-center" style="color: #94a3b8; font-size: 0.875rem; text-align: center;">
        © {new Date().getFullYear()} Sumannaba. All rights reserved.
      </p>
    </div>
  </div>
</footer>
